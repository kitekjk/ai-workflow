# Copy this file to `.env` and fill values locally.
#
# Never commit `.env`. It contains personal/API credentials and is ignored by
# Git. The values below are examples and placeholders.
# Runtime credential env keys are intentionally allowlisted in code. Do not add
# new token/password env names without updating the allowlist and redaction
# tests in `src/runtime/secrets.ts`.
TZ=Asia/Seoul

# Runtime mode:
# - stub: uses seeded in-memory Jira/Git/Wiki data. Good for local tests.
# - real: reads Jira, commits to the configured local PRD Git repo, and
#   publishes a Confluence page. Jira trigger is still manual through
#   `POST /prd/intake`.
INTEGRATION_MODE=stub

# Local HTTP port for `npm run start:api`.
WORKFLOW_API_PORT=3000

# Runtime store for scheduler, runner APIs, and document artifact APIs.
# - memory: default fixture-backed local mode.
# - mysql: uses WORKFLOW_MYSQL_* repositories for scheduler/job/artifact APIs.
WORKFLOW_RUNTIME_STORE=memory
WORKFLOW_JOB_LEASE_MS=30000
# MySQL-only escape hatch for repository/read-model and runner APIs without the
# legacy PRD compatibility fixture. PRD transition endpoints return 501 until
# the repository-backed transition engine is enabled.
WORKFLOW_COMPATIBILITY_FIXTURE=enabled
# Compatibility workflow background interval in milliseconds. Enabled by
# default when the compatibility fixture is active. Use 0 or disabled to keep
# only the manual dev/test `POST /tick` trigger.
WORKFLOW_INTERNAL_TICK_MS=1000

# Optional local MySQL for the future persistent workflow store.
# Start with:
#   docker compose --profile workflow-db up -d workflow-mysql
# Apply migrations with:
#   npm run db:migrate:mysql
WORKFLOW_MYSQL_HOST=127.0.0.1
WORKFLOW_MYSQL_PORT=3306
WORKFLOW_MYSQL_DATABASE=ai_workflow
WORKFLOW_MYSQL_USER=ai_workflow
WORKFLOW_MYSQL_PASSWORD=ai_workflow
WORKFLOW_MYSQL_ROOT_PASSWORD=ai_workflow_root

# Stub quality gate control:
# - false: force `needs_revision` after PRD quality evaluation.
# - true: move the PRD workflow to `awaiting_approval`.
STUB_QUALITY_PASSES=false

# PRD runner skill mode:
# - stub: no real PRD repo/wiki writes; returns deterministic fake artifacts.
# - adapter: template-based PRD markdown, committed to PRD repo and published.
# - cli: call Claude CLI or Codex CLI to generate/evaluate/revise PRD content,
#   then commit/publish the returned markdown.
RUNNER_SKILL_MODE=adapter

# CLI runner settings used when RUNNER_SKILL_MODE=cli.
# The workflow starts a local bridge script, which calls the selected CLI and
# expects it to return structured JSON for the PRD task.
RUNNER_ENGINE=claude
CLAUDE_CLI_PATH=claude
CODEX_CLI_PATH=codex
RUNNER_CLI_TIMEOUT_MS=120000

# Optional model override passed to Claude/Codex CLI.
RUNNER_CLI_MODEL=

# Optional default Codex sandbox for CLI jobs. A job template can override it.
# Allowed: read-only, workspace-write, danger-full-access.
RUNNER_CLI_SANDBOX=read-only

# Human-readable output language for generated PRDs and quality results.
# Use `ko` for Korean, `en` for English, or another explicit language name.
RUNNER_OUTPUT_LANGUAGE=ko

# Claude CLI only: maximum turns for non-interactive `claude -p`.
RUNNER_CLI_MAX_TURNS=3

# Local runner process settings for `npm run start:local-runner`.
# This lets a developer/planner PC poll the central Workflow API and execute
# only jobs assigned to its owner/scope/capabilities.
WORKFLOW_API_BASE_URL=http://127.0.0.1:3000
LOCAL_RUNNER_ID=runner-yourname-laptop
LOCAL_RUNNER_OWNER_USER_ID=yourname@example.com
LOCAL_RUNNER_MODE=local
LOCAL_RUNNER_CAPABILITIES=document.generate,document.evaluate
# Add these only on PCs allowed to operate implementation PRs:
# LOCAL_RUNNER_CAPABILITIES=document.generate,document.evaluate,implementation.open_pr,implementation.collect_pr_status
LOCAL_RUNNER_ALLOWED_PROJECT_IDS=
LOCAL_RUNNER_ALLOWED_REPOSITORY_IDS=
LOCAL_RUNNER_TEAM_IDS=
LOCAL_RUNNER_CONCURRENCY=1
LOCAL_RUNNER_ONCE=false
LOCAL_RUNNER_POLL_INTERVAL_MS=5000
LOCAL_RUNNER_RETRYABLE_ENGINE_ERRORS=true
LOCAL_RUNNER_WORKSPACE_ROOT=.runner-workspaces
LOCAL_RUNNER_CLEAN_WORKSPACE=true

# Jira Cloud settings for real mode:
# - Use the canonical Atlassian site URL, not a browser/custom domain.
#   Example: https://musinsa-oneteam.atlassian.net
# - API token can be the same Atlassian token used for Confluence.
# - Manual trigger example:
#   curl -X POST http://127.0.0.1:3000/prd/intake \
#     -H 'content-type: application/json' \
#     -d '{"prdJiraKey":"PAIR-2"}'
JIRA_BASE_URL=https://your-site.atlassian.net

# Jira auth mode:
# - basic: Jira Cloud email + API token. Recommended for Atlassian Cloud.
# - bearer: Jira Server/Data Center PAT style. Not normally needed for Cloud.
JIRA_AUTH_MODE=basic

# Jira REST API version:
# - 3: Jira Cloud default.
# - 2: useful for older/server-style installations.
JIRA_API_VERSION=3

# Atlassian account email and API token.
# Create/manage tokens at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=
JIRA_API_TOKEN=

# Jira writeback allowlist for workflow metadata.
# Configure these with your Jira custom field ids before enabling writeback.
JIRA_FIELD_WORKFLOW_RUN_ID=customfield_10010
JIRA_FIELD_CURRENT_ARTIFACT_URL=customfield_10011
JIRA_FIELD_GATE_STATUS=customfield_10012
JIRA_FIELD_QUALITY_SCORE=customfield_10013

# Jira workflow transition ids used by approval/writeback actions.
# Transition ids are Jira-project specific; keep empty until confirmed.
JIRA_TRANSITION_AWAITING_APPROVAL_ID=
JIRA_TRANSITION_APPROVED_ID=
JIRA_TRANSITION_REJECTED_ID=
JIRA_TRANSITION_NEEDS_REVISION_ID=

# PRD repository for real mode:
# - Must be a local Git repository/clone on this machine.
# - The runner commits PRD files directly to the current branch under
#   `prds/<JIRA_KEY>.md`.
# - Configure git identity in that repo before running:
#   git config user.email "workflow@example.com"
#   git config user.name "AI Workflow"
PRD_REPO_PATH=/absolute/path/to/prd-repo

# Optional public URL prefix for links shown in workflow state.
# Leave empty to return file:// URLs.
# Example: https://github.com/org/prd-repo/blob/main
PRD_REPO_PUBLIC_BASE_URL=https://github.com/org/prd-repo/blob/main

# GitHub integration for implementation branch/PR/status collection.
# Use a fine-grained token scoped to the target repository.
GITHUB_BASE_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_OWNER=org
GITHUB_REPO=service-repo
GITHUB_API_VERSION=2022-11-28
GITHUB_DEFAULT_BASE_BRANCH=main

# Confluence wiki replica for real mode:
# - Use the same canonical Atlassian site URL as Jira for Atlassian Cloud.
# - The page is created under CONFLUENCE_PARENT_PAGE_ID.
# - CONFLUENCE_PARENT_PAGE_ID may be either the numeric page id or a full
#   Confluence page URL containing `/pages/<id>/...`.
CONFLUENCE_BASE_URL=https://your-site.atlassian.net
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# Space key where PRD pages should be published.
# Example from the current test setup: LOGISSOL
CONFLUENCE_SPACE_KEY=

# Parent Confluence page id or full page URL.
# Examples:
#   454396379
#   https://your-site.atlassian.net/wiki/spaces/LOGISSOL/pages/454396379/Page+Title
CONFLUENCE_PARENT_PAGE_ID=

# Optional type-specific parent pages. When omitted, CONFLUENCE_PARENT_PAGE_ID
# is used as the fallback for that document type.
CONFLUENCE_PARENT_PAGE_ID_PRD=
CONFLUENCE_PARENT_PAGE_ID_HLD=
CONFLUENCE_PARENT_PAGE_ID_LLD=
CONFLUENCE_PARENT_PAGE_ID_ADR=
CONFLUENCE_PARENT_PAGE_ID_SPEC=
