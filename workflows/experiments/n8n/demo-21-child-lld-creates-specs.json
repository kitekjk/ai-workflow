        "jsCode": "const output = [];\nfor (const item of items) {\n  const specs = item.json.planned_specs || [];\n  for (const spec of specs) {\n    output.push({\n      json: {\n        project_key: item.json.project_key,\n        hld_issue: item.json.hld_issue,\n        hld_artifact: item.json.hld_artifact,\n        lld_issue: item.json.lld_issue,\n        lld_name: item.json.lld_name,\n        lld_artifact: item.json.target_path,\n        lld_quality_score: item.json.lld_quality_score,\n        target_repo: item.json.target_repo,\n        spec_issue: spec.spec_issue,\n        spec_name: spec.spec_name,\n        target_path: spec.target_path\n      }\n    });\n  }\n}\nreturn output;"
